@page "/terminal"
@using ElectronicQueue.Models
@using ElectronicQueue.Services
@inject QueueService QService
@rendermode InteractiveServer

<div class="terminal-main">
    <div class="glass-card">
        <div class="terminal-header">
            <div class="bank-logo">🏦 SmartBank</div>
            <h1>Ласкаво просимо!</h1>
            <p class="subtitle">Будь ласка, оберіть категорію для отримання талона</p>
        </div>

        <div class="options-container">
            <button class="opt-btn blue" @onclick='() => Register("Касові операції")'>
                <div class="btn-icon">💰</div>
                <div class="btn-text">
                    <strong>Касові операції</strong>
                    <span>Валюта, платежі, перекази</span>
                </div>
            </button>

            <button class="opt-btn green" @onclick='() => Register("Кредитування")'>
                <div class="btn-icon">💳</div>
                <div class="btn-text">
                    <strong>Кредитний відділ</strong>
                    <span>Авто, іпотека, картки</span>
                </div>
            </button>

            <button class="opt-btn gold" @onclick='() => Register("Консультація")'>
                <div class="btn-icon">ℹ️</div>
                <div class="btn-text">
                    <strong>Консультація</strong>
                    <span>Загальні питання та довідки</span>
                </div>
            </button>
        </div>

        @if (lastTicket != null)
        {
            <div class="ticket-overlay">
                <div class="printed-ticket">
                    <div class="ticket-head">ВАШ НОМЕР</div>
                    <div class="ticket-val">@lastTicket.QueueNumber</div>
                    <div class="ticket-type">@lastTicket.ServiceType</div>
                    <div class="ticket-time">@lastTicket.CreatedAt.ToString("dd.MM.yyyy HH:mm")</div>
                    <div class="ticket-footer">Будь ласка, очікуйте виклику</div>
                    <button class="close-btn" @onclick="() => lastTicket = null">ОК</button>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .terminal-main {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
        padding: 20px;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 30px;
        padding: 50px;
        width: 100%;
        max-width: 900px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.1);
        text-align: center;
    }

    .bank-logo { color: #1a237e; font-weight: 800; letter-spacing: 1px; margin-bottom: 10px; }
    h1 { font-weight: 800; color: #333; font-size: 2.5rem; }
    .subtitle { color: #666; font-size: 1.1rem; margin-bottom: 40px; }

    .options-container {
        display: grid;
        grid-template-columns: 1fr;
        gap: 15px;
    }

    .opt-btn {
        display: flex;
        align-items: center;
        padding: 20px 30px;
        border: none;
        border-radius: 20px;
        cursor: pointer;
        transition: all 0.2s;
        text-align: left;
    }

    .opt-btn:hover { transform: scale(1.02); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
    
    .btn-icon { font-size: 2.5rem; margin-right: 25px; }
    .btn-text strong { display: block; font-size: 1.3rem; }
    .btn-text span { font-size: 0.9rem; opacity: 0.8; }

    .blue { background: #e3f2fd; color: #0d47a1; }
    .green { background: #e8f5e9; color: #1b5e20; }
    .gold { background: #fffde7; color: #f57f17; }

    /* Анімація Талона */
    .ticket-overlay {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.5);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 100;
    }

    .printed-ticket {
        background: white;
        padding: 40px;
        border-radius: 10px;
        border-top: 8px solid #1a237e;
        width: 300px;
        animation: slideIn 0.4s ease-out;
    }

    .ticket-head { font-size: 0.9rem; letter-spacing: 2px; color: #999; }
    .ticket-val { font-size: 5rem; font-weight: 900; color: #000; margin: 10px 0; }
    .ticket-type { font-weight: bold; border-bottom: 1px dashed #ccc; padding-bottom: 10px; }
    .ticket-time { font-size: 0.8rem; margin: 10px 0; color: #666; }
    .close-btn { 
        margin-top: 20px; width: 100%; padding: 10px; 
        background: #1a237e; color: white; border: none; border-radius: 5px; 
    }

    @@keyframes slideIn {
        from { transform: translateY(100px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
</style>

@code {
    private Client? lastTicket;
    private void Register(string service) => lastTicket = QService.RegisterClient(service);
}
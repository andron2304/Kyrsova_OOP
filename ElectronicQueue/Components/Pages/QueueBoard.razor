@page "/board"
@using ElectronicQueue.Services
@inject QueueService QService
@implements IDisposable
@rendermode InteractiveServer

<div class="board-wrapper">
    <div class="header-panel">
        <div class="clock">@DateTime.Now.ToString("HH:mm:ss")</div>
        <h1>📺 ІНФОРМАЦІЙНЕ ТАБЛО</h1>
        <div class="status-badge">ONLINE</div>
    </div>

    <div class="main-grid">
        <div class="calling-section">
            <div class="section-label">ЗАРАЗ ВИКЛИКАЮТЬСЯ</div>
            <div class="calling-list">
                @if (!QService.GetCallingClients().Any())
                {
                    <div class="empty-state">Очікуйте виклику...</div>
                }
                @foreach (var client in QService.GetCallingClients())
                {
                    <div class="call-card">
                        <div class="ticket-part">
                            <span class="label">ТАЛОН</span>
                            <span class="number">@client.QueueNumber</span>
                        </div>
                        <div class="arrow">→</div>
                        <div class="service-part">
                            <span class="label">ПОСЛУГА</span>
                            <span class="name">@client.ServiceType</span>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="waiting-section">
            <div class="section-label">В ЧЕРЗІ</div>
            <div class="waiting-grid">
                @foreach (var client in QService.GetWaitingClients())
                {
                    <div class="waiting-token">
                        № @client.QueueNumber
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .board-wrapper {
        background: #121212;
        color: white;
        min-height: 90vh;
        border-radius: 20px;
        padding: 30px;
        font-family: 'Segoe UI', Roboto, sans-serif;
    }

    .header-panel {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 2px solid #333;
        padding-bottom: 20px;
        margin-bottom: 30px;
    }

    .clock { font-size: 1.5rem; color: #ffc107; font-weight: bold; }
    .status-badge { background: #28a745; padding: 5px 15px; border-radius: 20px; font-size: 0.8rem; }

    .main-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 30px;
    }

    .section-label {
        background: #333;
        padding: 10px 20px;
        border-radius: 10px;
        font-weight: bold;
        margin-bottom: 20px;
        letter-spacing: 2px;
    }

    /* Стиль карток виклику */
    .call-card {
        background: linear-gradient(135deg, #1e7e34 0%, #155724 100%);
        border-radius: 20px;
        padding: 40px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        animation: blink-shadow 2s infinite;
    }

    .ticket-part, .service-part { display: flex; flex-direction: column; }
    .label { font-size: 1rem; opacity: 0.7; }
    .number { font-size: 6rem; font-weight: 900; line-height: 1; }
    .name { font-size: 2.5rem; font-weight: bold; }
    .arrow { font-size: 4rem; color: #ffc107; }

    /* Список очікування */
    .waiting-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
        gap: 15px;
    }

    .waiting-token {
        background: #2c2c2c;
        padding: 15px;
        border-radius: 10px;
        text-align: center;
        font-size: 1.5rem;
        font-weight: bold;
        border: 1px solid #444;
    }

    .empty-state {
        font-size: 2rem;
        color: #555;
        text-align: center;
        margin-top: 100px;
    }

    @@keyframes blink-shadow {
        0% { box-shadow: 0 0 0px rgba(40, 167, 69, 0); }
        50% { box-shadow: 0 0 30px rgba(40, 167, 69, 0.5); }
        100% { box-shadow: 0 0 0px rgba(40, 167, 69, 0); }
    }
</style>

@code {
    protected override void OnInitialized()
    {
        QService.OnQueueChanged += RefreshMe;
    }

    private void RefreshMe()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        QService.OnQueueChanged -= RefreshMe;
    }
}
@page "/operator"
@using ElectronicQueue.Models
@using ElectronicQueue.Services
@inject QueueService QService
@implements IDisposable
@rendermode InteractiveServer

<div class="operator-container">
    <div class="header-row">
        <h2>👨‍💼 Панель Оператора</h2>
        <div class="status-indicator">Каса №1 • Працює</div>
    </div>

    <div class="dashboard-grid">
        <div class="current-client-card shadow">
            <div class="card-tag">ПОТОЧНИЙ КЛІЄНТ</div>
            @if (currentClient != null)
            {
                <div class="client-info">
                    <div class="queue-number">№ @currentClient.QueueNumber</div>
                    <div class="service-tag">@currentClient.ServiceType</div>
                    <div class="time-in-work">В роботі з: @DateTime.Now.ToString("HH:mm")</div>
                </div>
                <button class="btn-finish" @onclick="FinishServing">✅ Завершити обслуговування</button>
            }
            else
            {
                <div class="no-client">
                    <span class="icon">☕</span>
                    <p>Зараз немає клієнта на обслуговуванні</p>
                </div>
            }
        </div>

        <div class="stats-panel shadow">
            <div class="stat-item">
                <span class="stat-label">В очікуванні</span>
                <span class="stat-value">@QService.GetWaitingClients().Count() ч.</span>
            </div>
            <div class="stat-item">
                <span class="stat-label">Всього за зміну</span>
                <span class="stat-value text-primary">@QService.GetAllClients().Count()</span>
            </div>
            
            <button class="btn-call-next @(QService.GetWaitingClients().Any() ? "active" : "disabled")" 
                    @onclick="CallNext" 
                    disabled="@(!QService.GetWaitingClients().Any() || currentClient != null)">
                🔔 Викликати наступного
            </button>
            
            @if (!QService.GetWaitingClients().Any() && currentClient == null)
            {
                <p class="empty-msg">Черга порожня. Можна відпочити! 🍩</p>
            }
        </div>
    </div>
</div>

<style>
    .operator-container {
        padding: 20px;
        font-family: 'Segoe UI', sans-serif;
    }

    .header-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }

    .status-indicator {
        background: #e8f5e9;
        color: #2e7d32;
        padding: 5px 15px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 25px;
    }

    .current-client-card {
        background: white;
        border-radius: 20px;
        padding: 40px;
        text-align: center;
        border-top: 6px solid #1a237e;
    }

    .card-tag { font-size: 0.8rem; color: #999; letter-spacing: 2px; margin-bottom: 20px; }
    
    .queue-number { font-size: 5rem; font-weight: 900; color: #1a237e; line-height: 1; }
    .service-tag { 
        display: inline-block; background: #f0f2f5; padding: 5px 20px; 
        border-radius: 50px; margin: 15px 0; font-weight: 600; 
    }

    .btn-finish {
        width: 100%; padding: 15px; border: none; border-radius: 12px;
        background: #2e7d32; color: white; font-weight: bold; cursor: pointer;
        margin-top: 25px; transition: 0.2s;
    }

    .btn-call-next {
        width: 100%; padding: 20px; border: none; border-radius: 12px;
        font-weight: 800; font-size: 1.1rem; cursor: pointer; transition: 0.3s;
        margin-top: 20px;
    }

    .btn-call-next.active { background: #ffc107; color: #000; box-shadow: 0 5px 15px rgba(255,193,7,0.4); }
    .btn-call-next.disabled { background: #eee; color: #aaa; cursor: not-allowed; }

    .stats-panel { background: white; border-radius: 20px; padding: 30px; }
    .stat-item { display: flex; justify-content: space-between; padding: 15px 0; border-bottom: 1px solid #eee; }
    .stat-value { font-size: 1.4rem; font-weight: 700; }
    
    .no-client .icon { font-size: 4rem; display: block; margin-bottom: 10px; }
    .empty-msg { color: #888; text-align: center; margin-top: 15px; font-style: italic; }
    
    .shadow { box-shadow: 0 10px 25px rgba(0,0,0,0.05); }
</style>

@code {
    private Client? currentClient;

    protected override void OnInitialized() => QService.OnQueueChanged += Refresh;

    private void CallNext()
    {
        currentClient = QService.CallNextClient();
    }

    private void FinishServing()
    {
        if (currentClient != null)
        {
            QService.FinishClient(currentClient.QueueNumber);
            currentClient = null;
        }
    }

    private void Refresh() => InvokeAsync(StateHasChanged);
    public void Dispose() => QService.OnQueueChanged -= Refresh;
}
@page "/operator"
@using ElectronicQueue.Models
@inject QueueSystem Queue
@implements IQueueObserver
@implements IDisposable

<div class="container-fluid mt-4 mb-5 px-4">
    <div class="row g-4">
        
        <div class="col-xl-4 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4 h-100 overflow-hidden">
                <div class="card-header bg-success text-white text-center py-4 border-0">
                    <i class="bi bi-headset display-4 mb-2 d-block"></i>
                    <h3 class="mb-0 fw-bold">Робоче місце оператора</h3>
                </div>
                
                <div class="card-body p-4 d-flex flex-column justify-content-center text-center bg-white">
                    @if (currentTicket != null)
                    {
                        <div class="mb-2">
                            <span class="badge bg-warning text-dark fs-6 px-3 py-2 rounded-pill animate__animated animate__pulse animate__infinite">
                                <i class="bi bi-circle-fill text-danger me-2" style="font-size: 0.6rem;"></i>Зараз обслуговується
                            </span>
                        </div>
                        
                        <h1 class="display-1 fw-black text-success my-3" style="font-size: 5rem;">#@currentTicket.Number</h1>
                        
                        <div class="client-info text-start bg-light p-4 rounded-4 border mb-4 shadow-sm">
                            <h4 class="fw-bold mb-3">
                                <i class="bi bi-person-circle text-secondary me-2"></i> @currentTicket.ClientName
                            </h4>
                            
                            @if(!string.IsNullOrEmpty(currentTicket.Comment))
                            {
                                <div class="p-3 bg-white rounded-3 border-start border-success border-4 mb-3">
                                    <p class="text-dark mb-0"><i class="bi bi-chat-quote-fill text-success opacity-50 me-2"></i> @currentTicket.Comment</p>
                                </div>
                            }
                            
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <span class="badge bg-secondary fs-6">@currentTicket.ServiceType</span>
                                <span class="text-muted small"><i class="bi bi-clock me-1"></i> Очікує з @currentTicket.IssueTime.ToString("HH:mm")</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="py-5 my-4">
                            <i class="bi bi-cup-hot-fill text-muted display-1 opacity-25 mb-3 d-block"></i>
                            <h2 class="text-muted fw-bold">Вільна каса</h2>
                            <p class="text-muted mb-0">Очікування клієнта...</p>
                        </div>
                    }

                    <div class="mt-auto pt-3">
                        <button class="btn btn-lg btn-success w-100 py-3 fw-bold shadow-sm rounded-pill hover-lift" 
                                @onclick="CallNextPatient" 
                                disabled="@(Queue.GetWaitingCount() == 0)">
                            <i class="bi bi-megaphone-fill me-2"></i> Автоматичний виклик
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-8 col-lg-7">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-header bg-dark text-white p-4 d-flex justify-content-between align-items-center rounded-top-4 border-0">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-list-ul me-2"></i> Черга очікування</h5>
                    <span class="badge bg-light text-dark fs-6 rounded-pill px-3 py-2 shadow-sm">
                        Очікують: <span class="fw-bold fs-5 text-primary ms-1">@Queue.GetWaitingCount()</span>
                    </span>
                </div>
                
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height: 70vh; overflow-y: auto;">
                        <table class="table table-hover align-middle mb-0 custom-table">
                            <thead class="table-light sticky-top shadow-sm">
                                <tr>
                                    <th class="ps-4 py-3 text-uppercase text-muted small fw-bold">Номер</th>
                                    <th class="py-3 text-uppercase text-muted small fw-bold">Клієнт</th>
                                    <th class="py-3 text-uppercase text-muted small fw-bold">Питання</th>
                                    <th class="py-3 text-uppercase text-muted small fw-bold">Час</th>
                                    <th class="text-end pe-4 py-3 text-uppercase text-muted small fw-bold">Дія</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Queue.GetWaitingCount() == 0)
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-5">
                                            <div class="py-4">
                                                <i class="bi bi-inbox fs-1 text-muted opacity-50 d-block mb-3"></i>
                                                <h5 class="text-muted">Черга порожня</h5>
                                                <p class="text-muted small mb-0">Нові талони з'являться тут автоматично</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var ticket in Queue.GetAll().Where(t => t.Status == "В черзі").OrderByDescending(t => t.IsPriority).ThenBy(t => t.IssueTime))
                                    {
                                        <tr class="@(ticket.IsPriority ? "priority-row" : "standard-row") transition-all">
                                            <td class="ps-4 py-3">
                                                <span class="fs-5 fw-bold @(ticket.IsPriority ? "text-warning" : "text-dark")">#@ticket.Number</span>
                                                @if(ticket.IsPriority)
                                                {
                                                    <i class="bi bi-star-fill text-warning ms-1" data-bs-toggle="tooltip" title="Пільгова черга"></i>
                                                }
                                            </td>
                                            <td class="fw-bold py-3">@ticket.ClientName</td>
                                            <td class="text-muted py-3">
                                                @(string.IsNullOrEmpty(ticket.Comment) ? "—" : ticket.Comment)
                                            </td>
                                            <td class="text-muted small py-3">@ticket.IssueTime.ToString("HH:mm")</td>
                                            <td class="text-end pe-4 py-3">
                                                <button class="btn btn-outline-success btn-sm fw-bold rounded-pill px-4 call-btn hover-lift" 
                                                        @onclick="() => CallSpecificPatient(ticket.Number)">
                                                    Викликати <i class="bi bi-arrow-right-short fs-5 align-middle"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private Ticket? currentTicket;

    protected override void OnInitialized()
    {
        Queue.Attach(this);
        currentTicket = Queue.GetAll().LastOrDefault(t => t.Status == "Викликано");
    }

    public void Update(Ticket ticket)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Queue.Detach(this);
    }

    private void CallNextPatient()
    {
        currentTicket = Queue.CallNext();
        StateHasChanged();
    }

    // РУЧНИЙ виклик клієнта з таблиці
    private void CallSpecificPatient(int number)
    {
        currentTicket = Queue.CallSpecific(number);
        StateHasChanged();
    }
}

<style>
    .fw-black { font-weight: 900; }
    .hover-lift { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .hover-lift:hover { transform: translateY(-2px); box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important; }
    .hover-lift:active { transform: translateY(0); }
    
    .transition-all { transition: all 0.2s ease-in-out; }
    
    .priority-row { background-color: rgba(255, 193, 7, 0.05); }
    .priority-row:hover { background-color: rgba(255, 193, 7, 0.15) !important; }
    
    .standard-row:hover { background-color: rgba(0, 0, 0, 0.02) !important; }
    
    .custom-table th { letter-spacing: 0.5px; }
    
    /* Кастомізація скролу для таблиці */
    .table-responsive::-webkit-scrollbar { width: 8px; }
    .table-responsive::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 4px; }
    .table-responsive::-webkit-scrollbar-thumb { background: #ccc; border-radius: 4px; }
    .table-responsive::-webkit-scrollbar-thumb:hover { background: #999; }
</style>
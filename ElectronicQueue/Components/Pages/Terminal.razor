@page "/terminal"
@using ElectronicQueue.Models
@inject QueueSystem Queue

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="bg-primary p-4 text-white text-center shadow">
                    <i class="bi bi-person-plus-fill display-1"></i>
                    <h1 class="fw-bold mb-0">SmartQueue Pro</h1>
                    <p class="lead opacity-75">Електронна система реєстрації клієнтів</p>
                </div>

                <div class="card-body p-5">
                    <div class="row mb-4">
                        <div class="col-6">
                            <div class="p-3 bg-light rounded shadow-sm border-top border-primary border-4 text-center">
                                <small class="text-muted d-block text-uppercase fw-bold">Всього в черзі</small>
                                <span class="h4 fw-bold text-primary">@Queue.GetWaitingCount() осіб</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3 bg-light rounded shadow-sm border-top border-warning border-4 text-center">
                                <small class="text-muted d-block text-uppercase fw-bold">Зараз обслуговується</small>
                                <span class="h4 fw-bold text-warning">#@(Queue.GetCurrentNumber() ?? 0)</span>
                            </div>
                        </div>
                    </div>

                    <div class="text-center mb-4">
                        <h3 class="fw-bold text-dark">Оформлення талона</h3>
                        <p class="text-muted">Будь ласка, введіть ваші дані для реєстрації</p>
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger fw-bold shadow-sm animate__animated animate__shakeX" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @errorMessage
                        </div>
                    }

                    <div class="mb-4 p-4 bg-light rounded-4 border">
                        <div class="mb-3 text-start">
                            <label class="form-label fw-bold text-secondary">Ваше ім'я:</label>
                            <input type="text" @bind="inputName" class="form-control form-control-lg border-2" placeholder="Як до вас звертатися?" />
                        </div>
                        <div class="mb-2 text-start">
                            <label class="form-label fw-bold text-secondary">Мета візиту (коментар):</label>
                            <input type="text" @bind="inputComment" class="form-control form-control-lg border-2" placeholder="Наприклад: Отримання картки..." />
                        </div>
                    </div>

                    <div class="d-grid gap-4">
                        <button class="btn btn-outline-primary btn-lg py-4 shadow-sm hover-zoom rounded-4" 
                                @onclick='() => TakeTicket("Загальна черга", false)'>
                            <div class="d-flex align-items-center justify-content-center">
                                <i class="bi bi-people-fill fs-1 me-3"></i>
                                <div class="text-start">
                                    <div class="fw-bold fs-4">Загальна черга</div>
                                    <small class="opacity-75">Стандартне обслуговування</small>
                                </div>
                            </div>
                        </button>

                        <button class="btn btn-outline-warning btn-lg py-4 shadow-sm hover-zoom rounded-4" 
                                @onclick='() => TakeTicket("Пільгова черга", true)'>
                            <div class="d-flex align-items-center justify-content-center text-dark">
                                <i class="bi bi-person-vcard-fill fs-1 me-3"></i>
                                <div class="text-start">
                                    <div class="fw-bold fs-4">Пільгова черга</div>
                                    <small class="opacity-75">Пріоритетне обслуговування</small>
                                </div>
                            </div>
                        </button>
                    </div>

                    @if (lastTicket != null)
                    {
                        <div class="mt-5 p-4 bg-white border-start border-success border-5 rounded-4 shadow animate__animated animate__zoomIn border">
                            <div class="row align-items-center">
                                <div class="col-lg-8">
                                    <h4 class="text-success fw-bold mb-3"><i class="bi bi-check-circle-fill me-2"></i>Талон успішно створено!</h4>
                                    <p class="mb-1 text-dark"><strong>👤 Клієнт:</strong> @lastTicket.ClientName</p>
                                    @if (!string.IsNullOrEmpty(lastTicket.Comment))
                                    {
                                        <p class="mb-3 text-dark"><strong>💬 Питання:</strong> @lastTicket.Comment</p>
                                    }
                                    
                                    <div class="p-3 bg-light rounded-3 border border-warning shadow-sm mt-3">
                                        <div class="d-flex align-items-center mb-1">
                                            <i class="bi bi-stopwatch text-warning fs-3 me-3"></i>
                                            <div>
                                                <div class="text-muted small text-uppercase fw-bold" style="font-size: 0.7rem;">Орієнтовний час очікування</div>
                                                <div class="fs-4 fw-bold text-dark">
                                                    @(lastTicket.EstimatedWaitMinutes == 0 ? "Менше хвилини" : $"~ {lastTicket.EstimatedWaitMinutes} хв")
                                                </div>
                                            </div>
                                        </div>
                                        <hr class="my-2 opacity-25">
                                        <div class="text-muted small">
                                            <i class="bi bi-people-fill me-1"></i> Перед вами в черзі: <strong>@lastTicket.PeopleAhead осіб</strong>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-4 text-center mt-3 mt-lg-0 border-start d-none d-lg-block">
                                    <div class="text-muted small text-uppercase fw-bold mb-1">Ваш номер</div>
                                    <div class="display-2 fw-black text-primary">#@lastTicket.Number</div>
                                    <span class="badge @(lastTicket.IsPriority ? "bg-warning text-dark" : "bg-secondary") rounded-pill px-3 py-2">
                                        @lastTicket.ServiceType
                                    </span>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="card-footer bg-light p-4 border-top">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-info-circle-fill text-info fs-4 me-3"></i>
                        <div>
                            <p class="mb-1 fw-bold text-dark">Інформація системи (UML Logic):</p>
                            <small class="text-muted d-block" style="font-size: 0.85rem;">
                                • <strong>Singleton:</strong> Всі дані синхронізовані через QueueSystem.<br>
                                • <strong>Priority Logic:</strong> Час очікування розраховується на основі вашої позиції в черзі.<br>
                                • <strong>Estimated Time:</strong> Кожна особа в черзі додає 5 хв до прогнозу.
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private Ticket? lastTicket;
    private string inputName = "";
    private string inputComment = "";
    private string errorMessage = "";

    private void TakeTicket(string service, bool priority)
    {
        // Перевірка на заповнення
        if (string.IsNullOrWhiteSpace(inputName) || string.IsNullOrWhiteSpace(inputComment))
        {
            errorMessage = "Будь ласка, введіть ім'я та коментар!";
            lastTicket = null;
            return;
        }

        errorMessage = ""; 

        // Викликаємо метод системи (який ми оновили в QueueSystem)
        lastTicket = Queue.AddTicket(service, priority, inputName, inputComment);
        
        // Очищуємо форму
        inputName = "";
        inputComment = "";
        
        StateHasChanged();
    }
}

<style>
    .fw-black { font-weight: 900; }
    .hover-zoom { transition: all 0.2s ease-in-out; }
    .hover-zoom:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; }
    .card { border-radius: 20px; }
    .form-control:focus { border-color: #0d6efd; box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15); }
</style>
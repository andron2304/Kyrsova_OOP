@page "/"

<div class="container mt-4">
    <div class="p-5 mb-4 rounded-4 shadow-lg text-white text-center" 
         style="background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);">
        <h1 class="display-3 fw-bold">SmartQueue Pro</h1>
        <p class="fs-4">Інтелектуальна система керування клієнтськими потоками</p>
        <hr class="my-4 opacity-25">
        <div class="d-flex justify-content-center gap-2 mb-3">
            <span class="badge bg-light text-dark">Zero Latency</span>
            <span class="badge bg-light text-dark">User Friendly</span>
            <span class="badge bg-light text-dark">UML Compliant</span>
        </div>
        <a href="terminal" class="btn btn-warning btn-lg px-5 fw-bold rounded-pill shadow">Розпочати роботу</a>
    </div>

    <h3 class="text-center mb-4 fw-bold">Основні модулі системи (за UML)</h3>
    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-3 rounded-4">
                <div class="card-body">
                    <i class="bi bi-ticket-perforated text-primary display-4"></i>
                    <h5 class="card-title mt-3 fw-bold">Термінал</h5>
                    <p class="text-muted small">Реєстрація об'єктів Ticket та призначення PriorityStrategy</p>
                    <a href="terminal" class="btn btn-outline-primary btn-sm rounded-pill">Відкрити →</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-3 rounded-4">
                <div class="card-body">
                    <i class="bi bi-broadcast text-danger display-4"></i>
                    <h5 class="card-title mt-3 fw-bold">Табло</h5>
                    <p class="text-muted small">Реалізація IQueueObserver для миттєвого оновлення стану</p>
                    <a href="board" class="btn btn-outline-danger btn-sm rounded-pill">Відкрити →</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-3 rounded-4">
                <div class="card-body">
                    <i class="bi bi-headset text-success display-4"></i>
                    <h5 class="card-title mt-3 fw-bold">Оператор</h5>
                    <p class="text-muted small">Керування чергою через Singleton-екземпляр QueueSystem</p>
                    <a href="operator" class="btn btn-outline-success btn-sm rounded-pill">Відкрити →</a>
                </div>
            </div>
        </div>
    </div>
</div>
@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar shadow" style="background: #2c3e50; width: 280px;">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 border-bottom">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">Документація</a>
        </div>

        <article class="content px-4 py-3">
            @Body
        </article>
    </main>
</div>

<style>
    /* Стиль для всієї сторінки, щоб фон був м'яким */
    main { background-color: #f8f9fa; min-height: 100vh; }
    .sidebar { min-height: 100vh; }
</style>